{
  "compilerOptions": {
    "target":    "ES2018",
    "module":    "CommonJS",
    "lib":       ["ES2018", "DOM"],
    "jsx":       "react-jsx",
    "strict":    true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl":   ".",
    "outDir":    "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
